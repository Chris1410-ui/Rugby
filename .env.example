# Copy to .env and fill with your Supabase project values.
# These are the PUBLIC (publishable / anon) values — safe for the browser.
# NEVER put the service_role key or any secret here.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# Web Push — clé VAPID PUBLIQUE (base64url). Publique par nature : sûre pour le
# navigateur. La clé PRIVÉE correspondante est un secret d'Edge Function (côté
# serveur uniquement), jamais ici. Générer une paire avec `npx web-push generate-vapid-keys`.
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
